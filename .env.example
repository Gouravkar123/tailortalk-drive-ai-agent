# ─────────────────────────────────────────
#  TailorTalk Environment Variables
# ─────────────────────────────────────────

# ── LLM Configuration (use at least one) ──
# Groq (recommended – fast & free tier): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here


# OpenAI (alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (alternative)
# GOOGLE_API_KEY=your_gemini_api_key_here

# ── Google Drive Configuration ────────────
# Path to your downloaded service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# For cloud deployments: paste the entire credentials.json content as a single-line JSON string
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# The Google Drive Folder ID to search within
# Get this from the folder URL: drive.google.com/drive/folders/FOLDER_ID_HERE
DRIVE_FOLDER_ID=1qkx58doSeYrcLjHPDysJyVJ36PsSqqlt

# ── App Configuration ─────────────────────
# Backend URL (used by Streamlit frontend)
BACKEND_URL=http://localhost:8000
